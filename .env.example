# SHERLOCK — environment configuration
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# Every variable below is optional — the app runs with zero configuration
# using local SQLite + NetworkX (see the defaults noted for each).

# --- Database ---------------------------------------------------------
# Defaults to a local SQLite file (sherlock.db in the repo root) if unset.
# Set this to point at Postgres for a "real" deployment:
DATABASE_URL=postgresql+psycopg2://sherlock:sherlock@localhost:5432/sherlock

# --- Graph backend ------------------------------------------------------
# "networkx" (default, in-memory, zero setup) or "neo4j" (requires the
# neo4j service below and the NEO4J_* variables).
GRAPH_BACKEND=networkx

# --- Neo4j (only used when GRAPH_BACKEND=neo4j) --------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sherlock123

# --- AI narrative generation ---------------------------------------------
# Optional. Without this, the Chief Investigation Officer's final report
# narrative falls back to a deterministic template built from structured
# findings directly (see backend/agents/chief/agent.py) — the investigation
# still runs and produces a full report either way.
ANTHROPIC_API_KEY=sk-ant-...

# --- Logging --------------------------------------------------------------
# DEBUG, INFO (default), WARNING, ERROR
LOG_LEVEL=INFO

# --- Security / Authentication (Stage E1) --------------------------------
# Defaults to false: every endpoint behaves exactly as it did at the end
# of Stage D, with no login required. Set to true to require a valid
# Bearer access token (see POST /auth/login) on every protected route.
SHERLOCK_AUTH_ENABLED=false

# Signs JWT access tokens. If unset, a random key is generated at process
# startup — fine for local dev, but tokens won't survive a restart and
# multiple instances won't trust each other's tokens. Always set this
# explicitly for a real deployment.
SHERLOCK_JWT_SECRET=

SHERLOCK_ACCESS_TOKEN_TTL_MINUTES=15
SHERLOCK_REFRESH_TOKEN_TTL_DAYS=14
SHERLOCK_MIN_PASSWORD_LENGTH=10

# If both are set, an Administrator account is created on first startup
# (only if no Administrator user exists yet) so an auth-enabled instance
# always has a way to log in. Rotate this password immediately after use.
SHERLOCK_BOOTSTRAP_ADMIN_USERNAME=
SHERLOCK_BOOTSTRAP_ADMIN_PASSWORD=

# --- Governance / Retention (Stage E5) ------------------------------------
# Days after closing/creation before a record is eligible for archival
# (archived_at is set — rows are never physically deleted). See
# POST /governance/retention/run (Administrator only).
SHERLOCK_SESSION_RETENTION_DAYS=730
SHERLOCK_CONVERSATION_RETENTION_DAYS=730
SHERLOCK_AUDIT_RETENTION_DAYS=1825

# --- Operational Security (Stage E6) ---------------------------------------
# Comma-separated allowed origins for CORS. Defaults to "*" (wide open —
# unchanged pre-Stage-E6 behavior). Set this for a real deployment.
SHERLOCK_CORS_ORIGINS=*

# Comma-separated allowed Host headers. Defaults to "*" (no restriction —
# TrustedHostMiddleware isn't even added in that case).
SHERLOCK_TRUSTED_HOSTS=*

# Rate limiting on /auth/login and /auth/refresh. Off by default so local
# dev and rapid test/validation runs are never accidentally throttled.
SHERLOCK_RATE_LIMIT_ENABLED=false
SHERLOCK_LOGIN_RATE_LIMIT=20/minute
SHERLOCK_REFRESH_RATE_LIMIT=60/minute

# "json" for structured JSON log lines (with request_id/correlation_id
# on every line); unset/anything else keeps the existing plain-text format.
SHERLOCK_LOG_FORMAT=

# TTS provider used by backend/voice — unchanged from Stage D, listed
# here because GET /health's "voice" component checks against it.
SHERLOCK_TTS_PROVIDER=espeak
